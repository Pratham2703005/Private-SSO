{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "allowJs": false,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
