{
  "name": "pratham-sso",
  "version": "0.0.1-beta.2",
  "description": "Production-ready SSO client SDK - Clerk/Auth0 level DX for your identity provider",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js",
      "require": "./dist/shared.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prepublishOnly": "npm run build && npm run type-check"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18.0.0",
    "next": "^14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "next": "16.1.6",
    "typescript": "^5.3.0",
    "tsup": "^7.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0"
  },
  "keywords": [
    "sso",
    "auth",
    "authentication",
    "oauth2",
    "pkce",
    "identity",
    "nextjs"
  ],
  "author": "Pratham Israni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/myown-sso-client.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
